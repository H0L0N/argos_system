# Argos System Configuration Template
# Copy this file to .env and fill in your values.

# --- Telegram API Configuration ---
# Get these from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here
# Format: +1234567890 (International format including country code)
PHONE_NUMBER=your_phone_number_here

# --- AI & LLM Configuration ---
# Required for SQL Agent and scoring logic
OPENAI_API_KEY=your_openai_key_here

# --- Database Connectivity ---
# Format: postgresql://user:password@localhost:5432/dbname
# Admin user (Owner of the 'app' schema)
DATABASE_URL=postgresql://argos:argos@localhost:5432/argos_system
# Restricted user (Read-only for natural language queries)
AGENT_DATABASE_URL=postgresql://sql_agent:sql_agent@localhost:5432/argos_system
